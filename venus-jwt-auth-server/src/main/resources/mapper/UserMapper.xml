<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kayleh.mapper.UserMapper">
    <select id="queryByUserName" resultType="com.kayleh.domain.UserPojo">
        select *
        from t_user_info
        where username = #{userName}
    </select>
    <select id="queryRoleByUserId" resultType="com.kayleh.domain.RolePojo">
        select r.id as id, r.role_name as roleName
        from t_user_role ur
                 join t_role r on r.id = ur.role_id
        where ur.user_id = #{userId}
    </select>
</mapper>
